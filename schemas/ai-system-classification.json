{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ai-act-compliance-agents/schemas/ai-system-classification.json",
  "title": "AI System Classification Memo Frontmatter",
  "description": "Schema for the YAML frontmatter of an EU AI Act risk-classification memo produced by the risk-classifier agent. Validates the structured opinion; the legal reviewer is responsible for final sign-off.",
  "type": "object",
  "required": [
    "id",
    "system_name",
    "provider",
    "intended_purpose",
    "deployment_context",
    "user_population",
    "foreseeable_misuse",
    "classification",
    "articles_cited",
    "annex_iii_check",
    "annex_i_check",
    "art_5_check",
    "classified_by",
    "reviewed_by",
    "classification_date",
    "review_due",
    "status",
    "substantial_modification_triggers"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^AI-SYS-[0-9]{4,}$",
      "description": "Stable identifier, e.g., AI-SYS-0001."
    },
    "system_name": { "type": "string", "minLength": 2 },
    "provider": { "type": "string", "minLength": 2 },
    "intended_purpose": {
      "type": "string",
      "minLength": 20,
      "description": "One testable sentence answering: what decision does this system make or support, for whom, with what consequence if wrong?"
    },
    "deployment_context": { "type": "string", "minLength": 2 },
    "user_population": { "type": "string", "minLength": 2 },
    "foreseeable_misuse": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 5 },
      "description": "Art. 9(2)(b) anchor; at least three entries required."
    },
    "classification": {
      "type": "string",
      "enum": ["prohibited", "high-risk", "limited-risk", "minimal-risk"]
    },
    "articles_cited": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(Art\\.\\s+\\d+(\\([0-9a-zA-Z]+\\))*|Annex\\s+[IVX]+(\\s+#\\d+)?|Recital\\s+\\d+)$"
      }
    },
    "annex_iii_check": { "type": "string", "minLength": 2 },
    "annex_i_check": { "type": "string", "minLength": 2 },
    "art_5_check": { "type": "string", "minLength": 2 },
    "classified_by": {
      "type": "string",
      "format": "email"
    },
    "reviewed_by": {
      "oneOf": [
        { "type": "string", "format": "email" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "format": "email" }
        }
      ]
    },
    "classification_date": { "type": "string", "format": "date" },
    "review_due": { "type": "string", "format": "date" },
    "status": {
      "type": "string",
      "enum": ["draft", "in_review", "approved", "superseded", "withdrawn"]
    },
    "substantial_modification_triggers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    },
    "supersedes": {
      "type": "string",
      "description": "Path or ID of the prior-version memo, if any."
    },
    "documentation_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    }
  }
}
